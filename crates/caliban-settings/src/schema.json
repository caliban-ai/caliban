{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://caliban.dev/schemas/settings/v1.json",
  "title": "Caliban Settings",
  "description": "Unified layered settings schema (ADR 0026). All fields are optional; unknown top-level keys are tolerated for forward-compat.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "agent": { "type": "string" },
    "model": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "properties": {
            "provider": { "type": "string" },
            "name": { "type": "string" }
          },
          "additionalProperties": false
        }
      ]
    },
    "fallback_model": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "properties": {
            "provider": { "type": "string" },
            "name": { "type": "string" }
          },
          "additionalProperties": false
        }
      ]
    },
    "model_overrides": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "permissions": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "allow": { "type": "array", "items": { "type": "string" } },
        "ask":   { "type": "array", "items": { "type": "string" } },
        "deny":  { "type": "array", "items": { "type": "string" } }
      }
    },
    "hooks": { "type": "object", "additionalProperties": true },
    "disable_all_hooks": { "type": "boolean" },
    "allow_managed_hooks_only": { "type": "boolean" },
    "allowed_http_hook_urls":   { "type": "array", "items": { "type": "string" } },
    "http_hook_allowed_env_vars": { "type": "array", "items": { "type": "string" } },
    "mcp_servers": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "type":      { "type": "string", "enum": ["stdio", "http", "sse"] },
          "transport": { "type": "string", "enum": ["stdio", "http", "sse"] },
          "command":   { "type": "string" },
          "args":      { "type": "array", "items": { "type": "string" } },
          "env":       { "type": "object", "additionalProperties": { "type": "string" } },
          "cwd":       { "type": "string" },
          "url":       { "type": "string" },
          "headers":   { "type": "object", "additionalProperties": { "type": "string" } },
          "oauth":     { "type": "string", "enum": ["off", "auto", "manual"] },
          "oauth_config": {
            "type": "object",
            "properties": {
              "client_id":     { "type": "string" },
              "client_secret": { "type": "string" },
              "auth_url":      { "type": "string" },
              "token_url":     { "type": "string" },
              "scopes":        { "type": "array", "items": { "type": "string" } },
              "audience":      { "type": "string" }
            },
            "additionalProperties": false
          },
          "permissions": {
            "type": "object",
            "properties": {
              "allow": { "type": "array", "items": { "type": "string" } },
              "deny":  { "type": "array", "items": { "type": "string" } },
              "ask":   { "type": "array", "items": { "type": "string" } }
            },
            "additionalProperties": false
          },
          "lazy":     { "type": "boolean" },
          "disabled": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "router": { "type": "object", "additionalProperties": true },
    "memory": {
      "type": "object",
      "properties": {
        "auto_memory_enabled":    { "type": "boolean" },
        "auto_memory_directory":  { "type": "string" },
        "cap_tokens_auto":        { "type": "integer", "minimum": 0 },
        "cap_tokens_claude_md":   { "type": "integer", "minimum": 0 },
        "cap_tokens_combined":    { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "plugins": { "type": "object", "additionalProperties": true },
    "output_style":  { "type": "string" },
    "editor_mode":   { "type": "string" },
    "view_mode":     { "type": "string" },
    "tui":           { "type": "object", "additionalProperties": true },
    "api_key_helper": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "properties": {
            "command": { "type": "string" },
            "provider": { "type": "string" },
            "refreshIntervalMs": { "type": "integer", "minimum": 0 },
            "slowHelperWarningMs": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": true,
          "required": ["command"]
        },
        {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "command": { "type": "string" },
              "provider": { "type": "string" }
            },
            "required": ["command"]
          }
        }
      ]
    },
    "enable_telemetry":      { "type": "boolean" },
    "auto_compact_threshold": { "type": ["number", "null"], "minimum": 0, "maximum": 1, "default": 0.75 },
    "micro_compact_enabled":  { "type": "boolean", "default": true },
    "tool_result_cap_chars":  { "type": "integer", "minimum": 0, "default": 50000 },
    "min_cache_block_tokens": { "type": "integer", "minimum": 0, "default": 1024 },
    "max_tokens_recovery":    { "type": "boolean", "default": true },
    "parent_settings_behavior": { "type": "string", "enum": ["block", "augment"] },
    "additional_directories":   { "type": "array", "items": { "type": "string" } },
    "claude_md_excludes":       { "type": "array", "items": { "type": "string" } },
    "env": { "type": "object", "additionalProperties": { "type": "string" } },
    "tools": {
      "type": "object",
      "properties": {
        "lazy_mcp":           { "type": "boolean", "default": false },
        "max_active_schemas": { "type": "integer", "minimum": 0, "default": 24 }
      },
      "additionalProperties": false
    },
    "effort": {
      "type": "string",
      "enum": ["low", "medium", "high", "max", "auto"]
    },
    "statusLine": {
      "type": "object",
      "properties": {
        "command":    { "type": "string" },
        "timeout_ms": { "type": "integer", "minimum": 50, "maximum": 5000 },
        "padding":    { "type": "integer", "minimum": 0, "maximum": 8 }
      },
      "required": ["command"],
      "additionalProperties": false
    },
    "tui": {
      "type": "object",
      "properties": {
        "showCostInStatusline": { "type": "boolean" }
      },
      "additionalProperties": true
    }
  }
}
