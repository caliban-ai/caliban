# Rust
target/
**/*.rs.bk
Cargo.lock.bak
*.rlib

# Editor / OS
*.swp
.DS_Store

# Python bytecode cache (transient; the project is migrating scripts off Python)
__pycache__/
*.pyc

# Superpowers brainstorm artifacts
.superpowers/

# Local environment things
.env*
!.env.example
.local*

# Per-user agent state / config (never committed)
.caliban/
.claude/

# Generated ADR copies for the mdBook guide (source of truth: docs/adr/)
/docs/guide/src/adr/

# Generated changelog copy for the mdBook guide (source of truth: CHANGELOG.md)
/docs/guide/src/changelog.md

# Shared theme files fetched from the hub at build time (source: caliban-ai.github.io)
/docs/guide/theme/caliban-ai.css
/docs/guide/theme/nav.js
